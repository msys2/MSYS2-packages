diff --git a/include/bsd/unistd.h b/include/bsd/unistd.h
index f246ac5d93fd..0d8afa32354c 100644
--- a/include/bsd/unistd.h
+++ b/include/bsd/unistd.h
@@ -25,6 +25,13 @@
  * ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.
  */
 
+/* While building libbsd itself, avoid a redefinition of 'setproctitle_init'
+ * error starting with unistd.h from Cygwin 3.6.0 onwards.
+*/
+#if defined(__BUILD_LIBBSD) && defined(__CYGWIN__)
+#define setproctitle_init __bsd_setproctitle_init
+#endif
+
 #ifdef LIBBSD_OVERLAY
 #include <sys/cdefs.h>
 #if __has_include_next(<unistd.h>)
@@ -46,6 +53,10 @@
 #define S_ISTXT S_ISVTX
 #endif
 
+#if defined(__BUILD_LIBBSD) && defined(__CYGWIN__)
+#undef setproctitle_init
+#endif
+
 __BEGIN_DECLS
 #if !defined(__APPLE__)
 extern int optreset;
