diff --git a/include/bsd/stdio.h b/include/bsd/stdio.h
index d67aab19fa0c..657f8688c62f 100644
--- a/include/bsd/stdio.h
+++ b/include/bsd/stdio.h
@@ -65,6 +65,11 @@ char *fgetln(FILE *fp, size_t *lenp)
 	                  "use getline(3) instead, as it is supported "
 	                  "by GNU and POSIX.1-2008.");
 
+/* newlib/Cygwin uses ssize_t as type of the size param so shadow the
+   following declaration */
+#ifdef __CYGWIN__
+#define funopen __bsd_funopen
+#endif
 /*
  * Note: We diverge from the FreeBSD, OpenBSD and DragonFlyBSD declarations,
  * because seekfn() there wrongly uses fpos_t, assuming it's an integral
@@ -82,6 +87,10 @@ FILE *funopen(const void *cookie,
 #define fropen(cookie, fn) funopen(cookie, fn, NULL, NULL, NULL)
 #define fwopen(cookie, fn) funopen(cookie, NULL, fn, NULL, NULL)
 
+#ifdef __CYGWIN__
+#undef funopen
+#endif
+
 int fpurge(FILE *fp);
 __END_DECLS
 
