#Maintainer: Erwin Waterlander <waterlan@xs4all.nl>

pkgname=wcd
pkgver=6.0.7
pkgrel=1
pkgdesc='Wherever Change Directory'
arch=('i686' 'x86_64')
url='https://waterlander.net/wcd/'
msys2_references=(
  "anitya: 341689"
)
license=('GPL')
depends=('libintl' 'libunistring' 'ncurses')
groups=('sys-utils')
makedepends=('perl' 'gettext-devel' 'libunistring-devel' 'ncurses-devel' 'make' 'gcc')
source=("https://waterlander.net/${pkgname}/files/${pkgname}-${pkgver}.tar.gz")
sha256sums=('91a63282a15e5df97b6797075d4b7600ad433c3216f4c76e538009363e857a3f')

prepare() {
  cd ${srcdir}/${pkgname}-${pkgver}
}

build() {
  cd ${srcdir}/${pkgname}-${pkgver}/src
  make
}

package() {
  cd ${srcdir}/${pkgname}-${pkgver}/src
  make DESTDIR=${pkgdir} install
  make DESTDIR=${pkgdir} install-profile
  cd ${srcdir}/${pkgname}-${pkgver}/doc
  install -D -m644 copying.txt ${pkgdir}/usr/share/licenses/${pkgname}/LICENSE
}
