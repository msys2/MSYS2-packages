# Maintainer: Alexey Pavlov <Alexpux@gmail.com>

_realname=Role-Tiny
pkgname=perl-${_realname}
pkgver=2.002005
pkgrel=1
pkgdesc="Roles. Like a nouvelle cuisine portion size slice of Moose."
arch=('any')
url="https://metacpan.org/dist/Role-Tiny"
msys2_references=(
  'purl: pkg:cpan/HAARG/Role-Tiny'
)
license=('PerlArtistic' 'GPL')
depends=('perl')
checkdepends=('perl-Test-Fatal>=0.003')
options=('!emptydirs')
source=(https://search.cpan.org/CPAN/authors/id/H/HA/HAARG/Role-Tiny-${pkgver}.tar.gz)
sha512sums=('34b41039113dff858b738541c949166d6f68310ae62cc009252b803b4bbaa8f56198dc852d3858e1ade940de3174866e00351e1094fe5b526e75b3fcf051430f')

prepare() {
  cd ${_realname}-${pkgver}
}

build() {
  cd ${_realname}-${pkgver}
  PERL_MM_USE_DEFAULT=1 \
  PERL_AUTOINSTALL=--skipdeps \
  PERL5LIB="" \
  MODULEBUILDRC=/dev/null \
  PERL_MM_OPT="INSTALLDIRS=vendor" \
  PERL_MB_OPT="--installdirs vendor" \
  perl Makefile.PL
  make
}

check() (
  cd ${_realname}-${pkgver}
  make test
)

package() {
  cd ${_realname}-${pkgver}
  make install DESTDIR="${pkgdir}"
}
