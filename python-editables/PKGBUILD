# Maintainer: Christoph Reiter <reiter.christoph@gmail.com>

_pyname=editables
pkgname=python-editables
pkgver=0.6
pkgrel=1
pkgdesc='A Python library for creating editable wheels'
arch=(any)
url='https://github.com/pfmoore/editables'
msys2_references=(
  "purl: pkg:pypi/editables"
)
license=('spdx:MIT')
depends=('python')
makedepends=(
  'python-build'
  'python-installer'
  'python-flit-core'
)
source=(https://github.com/pfmoore/editables/archive/$pkgver/$pkgname-$pkgver.tar.gz)
sha256sums=('766d9b40616dbcf5cc920e9db26dd915de999cfab75768ff05b3ebf9c389acb2')

build() {
  cd $_pyname-$pkgver
  python -m build --wheel --no-isolation
}

package() {
  cd $_pyname-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 LICENSE.txt -t "$pkgdir"/usr/share/licenses/$pkgname
}
