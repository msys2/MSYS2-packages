# Maintainer: Christoph Reiter <reiter.christoph@gmail.com>

_pyname=setuptools_gettext
pkgname=python-setuptools-gettext
pkgver=0.1.18
pkgrel=1
pkgdesc='Setuptools plugin for building .mo files'
arch=(any)
url=https://github.com/breezy-team/setuptools-gettext
msys2_repository_url="https://github.com/breezy-team/setuptools-gettext"
license=(spdx:GPL-2.0-or-later)
msys2_references=(
  'purl: pkg:pypi/setuptools-gettext'
)
depends=(
  python
  python-setuptools
)
makedepends=(
  python-build
  python-installer
)
source=("https://pypi.org/packages/source/${_pyname::1}/${_pyname}/${_pyname}-${pkgver}.tar.gz")
sha256sums=('c92b0ae486def502686cd944f16559819e42f8dc0b9d683cf62e7415397f2b35')

build() {
  cd "setuptools_gettext-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  python -m installer --destdir="${pkgdir}" "setuptools_gettext-${pkgver}"/dist/*.whl
}
