# Maintainer: Alexey Pavlov <alexpux@gmail.com>

pkgname=dos2unix
pkgver=7.5.6
pkgrel=1
pkgdesc='Text file format converter'
arch=('i686' 'x86_64')
url='https://waterlander.net/dos2unix/'
license=('spdx:BSD-2-Clause')
depends=('libintl')
makedepends=('perl' 'gettext-devel' 'gcc' 'make')
conflicts=('hd2u')
source=("https://waterlander.net/${pkgname}/files/${pkgname}-${pkgver}.tar.gz")
sha256sums=('63650acbd0c7fa8623429bcbf93a888e3351a1cad0f556cf41876f5673dd7d0b')

prepare() {
  cd ${srcdir}/${pkgname}-${pkgver}
}

build() {
  cd ${srcdir}/${pkgname}-${pkgver}
  make DEBUG=1
}

package() {
  cd ${srcdir}/${pkgname}-${pkgver}
  make DESTDIR=${pkgdir} install
  install -Dm755 ${pkgdir}/usr/bin/dos2unix.exe ${pkgdir}/usr/bin/d2u.exe
  install -Dm755 ${pkgdir}/usr/bin/unix2dos.exe ${pkgdir}/usr/bin/u2d.exe
  install -D -m644 COPYING.txt ${pkgdir}/usr/share/licenses/${pkgname}/LICENSE
}
