# Maintainer: Your Name <your.email@example.com>

pkgname=efitools
pkgver=1.9.2
pkgrel=1
pkgdesc="Tools for manipulating EFI secure variables"
arch=('i686' 'x86_64')
url="https://git.kernel.org/pub/scm/linux/kernel/git/jejb/efitools.git"
license=('GPL2')
depends=('openssl' 'libuuid' 'gnu-efi-devel')
makedepends=('gcc' 'make' 'help2man' 'openssl-devel' 'libuuid-devel')

_patches=('0001-Disable-building-EFIFILES-for-cygwin.patch')

source=(
  "https://git.kernel.org/pub/scm/linux/kernel/git/jejb/efitools.git/snapshot/efitools-${pkgver}.tar.gz"
  ${_patches[@]}
)

sha256sums=('0f315b36e7d1ba74bfc97ab9f304f0a3072c47578bbe5e42594acae381f9acfe'
            '0b364209407102b62f4bb4c0250d3c42173b784c07e3d355e52b00eba6312f64')

prepare() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  for patch in ${_patches[@]}; do
    msg2 "Patching with ${patch}"
    patch -p1 < "${srcdir}/${patch}"
  done
}

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  make
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  make DESTDIR="${pkgdir}" install
}
