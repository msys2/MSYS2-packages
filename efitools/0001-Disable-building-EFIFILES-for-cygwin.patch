From 375fd0174b0f56b476d20cea37e1d853e27ef2cc Mon Sep 17 00:00:00 2001
From: Yonggang Luo <luoyonggang@gmail.com>
Date: Mon, 20 Apr 2026 08:08:15 +0800
Subject: [PATCH] Disable building EFIFILES for cygwin

---
 Makefile            | 5 +----
 flash-var.c         | 2 ++
 sign-efi-sig-list.c | 2 ++
 3 files changed, 5 insertions(+), 4 deletions(-)

diff --git a/Makefile b/Makefile
index 7d471da..5db5dea 100644
--- a/Makefile
+++ b/Makefile
@@ -1,11 +1,9 @@
-EFIFILES = HelloWorld.efi LockDown.efi Loader.efi ReadVars.efi UpdateVars.efi \
-	KeyTool.efi HashTool.efi SetNull.efi ShimReplace.efi
+EFIFILES =
 BINARIES = cert-to-efi-sig-list sig-list-to-certs sign-efi-sig-list \
 	hash-to-efi-sig-list efi-readvar efi-updatevar cert-to-efi-hash-list \
 	flash-var
 
 ifeq ($(ARCH),x86_64)
-EFIFILES += PreLoader.efi
 endif
 
 MSGUID = 77FA9ABD-0359-4D32-BD60-28F4E78F784B
@@ -35,7 +33,6 @@ install: all
 	$(INSTALL) -m 755 -d $(MANDIR)
 	$(INSTALL) -m 644 $(MANPAGES) $(MANDIR)
 	$(INSTALL) -m 755 -d $(EFIDIR)
-	$(INSTALL) -m 755 $(EFIFILES) $(EFIDIR)
 	$(INSTALL) -m 755 -d $(BINDIR)
 	$(INSTALL) -m 755 $(BINARIES) $(BINDIR)
 	$(INSTALL) -m 755 mkusb.sh $(BINDIR)/efitool-mkusb
diff --git a/flash-var.c b/flash-var.c
index aa10ae6..a63417f 100644
--- a/flash-var.c
+++ b/flash-var.c
@@ -1,3 +1,5 @@
+#define _XOPEN_SOURCE 700 // Necessary for Cygwin
+
 #include <stdlib.h>
 #include <stdint.h>
 #include <sys/types.h>
diff --git a/sign-efi-sig-list.c b/sign-efi-sig-list.c
index 94bd7d4..aba1eb4 100644
--- a/sign-efi-sig-list.c
+++ b/sign-efi-sig-list.c
@@ -13,6 +13,8 @@
 #pragma GCC visibility pop
 #endif
 
+#define _XOPEN_SOURCE 700 // Necessary for Cygwin
+
 #include <stdio.h>
 #include <stdlib.h>
 #include <string.h>
-- 
2.52.0.windows.1

