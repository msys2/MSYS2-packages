# Maintainer: Alexey Pavlov <alexpux@gmail.com>

_realname=TimeDate
pkgname="perl-${_realname}"
pkgver=2.35
pkgrel=1
pkgdesc="Date formating subroutines"
arch=('any')
license=('spdx:Artistic-1.0-Perl')
url="https://metacpan.org/dist/TimeDate"
msys2_references=(
  "purl: pkg:cpan/ATOOMIC/TimeDate"
)
depends=('perl')
options=('!emptydirs')
source=("https://www.cpan.org/authors/id/A/AT/ATOOMIC/${_realname}-${pkgver}.tar.gz")
sha256sums=('baddd0306ae2e86e9ec28d3de5439e514643e80b3735e43bd0fbb426d73304de')

build() {
  cd ${_realname}-${pkgver}

  # install module in vendor directories.
  perl Makefile.PL INSTALLDIRS=vendor
  make
}

check() {
  cd ${_realname}-${pkgver}
  make test
}

package() {
  cd ${_realname}-${pkgver}
  make install DESTDIR="${pkgdir}"
}
