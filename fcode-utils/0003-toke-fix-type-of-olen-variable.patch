From 5b7bb554932f178786487f6b9b23e2af1c8f023f Mon Sep 17 00:00:00 2001
From: Aurelien Jarno <aurelien@aurel32.net>
Date: Sun, 9 Mar 2025 19:50:08 +0100
Subject: [PATCH 3/6] toke: fix type of olen variable

The olen variable is declared as unsigned int in toke/stream.c, but
simply as int in the extern definition in emit.c. This may cause
undefined behaviour, so fix that.

Signed-off-by: Aurelien Jarno <aurelien@aurel32.net>
---
 toke/emit.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/toke/emit.c b/toke/emit.c
index 010868e..eb41beb 100644
--- a/toke/emit.c
+++ b/toke/emit.c
@@ -133,7 +133,7 @@ static bool fcode_written = FALSE;
  **************************************************************************** */
 
 extern u8 *ostart;
-extern int olen;
+extern unsigned int olen;
 extern void increase_output_buffer( void);
 
 
