# Maintainer: Alexey Pavlov <alexpux@gmail.com>

pkgname=cvs
pkgver=1.11.23
pkgrel=5
pkgdesc="Concurrent Versions System - a source control system"
arch=('i686' 'x86_64')
license=('GPL')
url="http://cvs.nongnu.org/"
msys2_references=(
  "cpe: cpe:/a:cvs:cvs"
)
depends=('heimdal' 'zlib' 'libxcrypt' 'libopenssl')
makedepends=('groff' 'heimdal-devel' 'zlib-devel' 'gcc' 'libxcrypt-devel' 'openssl-devel' 'autotools')
options=('staticlibs')
_patches=(
  # patches from https://src.fedoraproject.org/rpms/cvs/blob/rawhide/f/cvs.spec
  # Use regexp 'Patch\d+: ' to replace prefixes

  # Fix up initial cvs login, bug #47457
  cvs-1.11.23-cvspass.patch
  # Build against system zlib
  cvs-1.11.19-extzlib.patch
  # Aadd 't' as a loginfo format specifier (print tag or branch name)
  cvs-1.11.19-netbsd-tag.patch
  # Deregister SIGABRT handler in clean-up to prevent loop, bug #66019
  cvs-1.11.19-abortabort.patch
  # Disable lengthy tests at build-time
  cvs-1.11.1p1-bs.patch
  # Improve proxy support, bug #144297
  cvs-1.11.21-proxy.patch
  # Do not accumulate new lines when reusing commit message, bug #64182
  cvs-1.11.19-logmsg.patch
  # Disable slashes in tag name, bug #56162
  cvs-1.11.19-tagname.patch
  # Fix NULL dereference, bug #63365
  cvs-1.11.19-comp.patch
  # Fix insecure temporary file handling in cvsbug, bug #166366
  cvs-1.11.19-tmp.patch
  # Add PAM support, bug #48937
  cvs-1.11.21-pam.patch
  # Report unknown file when calling cvs diff with two -r options, bug #18161
  cvs-1.11.21-diff.patch
  # Fix cvs diff -kk, bug #150031
  cvs-1.11.21-diff-kk.patch
  # Enable obsolete sort option called by rcs2log, bug #190009
  cvs-1.11.21-sort.patch
  # Add IPv6 support, bug #199404
  cvs-1.11.22-ipv6-proxy.patch
  # getline(3) returns ssize_t, bug #449424
  cvs-1.11.23-getline64.patch
  # Add support for passing arguments through standard input, bug #501942
  cvs-1.11.22-stdinargs.patch

  # CVE-2010-3864, bug #645386
  # CVE-2010-3864, https://www.redhat.com/security/data/cve/CVE-2010-3846.html
  cvs-1.11.23-cve-2010-3846.patch

  # Remove undefinded date from cvs(1) header, bug #225672
  cvs-1.11.23-remove_undefined_date_from_cvs_1_header.patch
  # Adjust tests to accept new style getopt argument quotation and SELinux label
  # notation from ls(1)
  cvs-1.11.23-sanity.patch
  # Run tests verbosely
  cvs-1.11.23-make_make_check_sanity_testing_verbose.patch
  # Set PAM_TTY and PAM_RHOST on PAM authentication
  cvs-1.11.23-Set-PAM_TTY-and-PAM_RHOST-on-PAM-authentication.patch
  # Add KeywordExpand configuration keyword
  cvs-1.11.23-Back-port-KeywordExpand-configuration-keyword.patch
  # bug #722972
  cvs-1.11.23-Allow-CVS-server-to-use-any-Kerberos-key-with-cvs-se.patch
  # CVE-2012-0804, bug #787683
  cvs-1.11.23-Fix-proxy-response-parser.patch
  # Correct texinfo syntax, bug #970716, submitted to upstream as bug #39166
  cvs-1.11.23-doc-Add-mandatory-argument-to-sp.patch
  # Excpect crypt(3) can return NULL, bug #966497, upstream bug #39040
  cvs-1.11.23-crypt-2.diff
  # Pass compilation with -Wformat-security, bug #1037029, submitted to upstream
  # as bug #40787
  cvs-1.11.23-Pass-compilation-with-Wformat-security.patch
  # Fix CVE-2017-1283 (command injection via malicious SSH URL), bug #1480801
  cvs-1.11.23-Fix-CVE-2017-12836.patch
  # Close a configuration file on a syntax error, bug #815660,
  # <http://savannah.nongnu.org/bugs/?36276>
  cvs-1.11.23-Close-a-configuration-file-on-a-syntax-error.patch
  # Do not use deprecated diff -L options, bug #772559,
  # <https://savannah.nongnu.org/bugs/?35267>
  cvs-1.11.23-Use-diff-label.patch
  # Enable cvs to build in C99 mode, bug #2187741
  cvs-1.11.23-c99.patch
  # Adjust tests to grep-3.9, proposed to the upstream,
  # <https://savannah.nongnu.org/bugs/index.php?64084>
  cvs-1.11.23-tests-Call-nonobsolete-grep-F.patch
  # Adapt to changes in GCC 15, bug #2340021, proposed to the upstream,
  # <https://savannah.nongnu.org/bugs/index.php?66726>
  cvs-1.11.23-Adapt-to-changes-in-GCC-15.patch

  # For cygwin
  cvs-1.11.23-Pass-server-IP-address-instead-of-hostname-to-GSSAPI.patch
)

source=(
  https://ftp.gnu.org/non-gnu/cvs/source/stable/${pkgver}/${pkgname}-${pkgver}.tar.bz2
  ${_patches[@]}
)

