# Contributor: Dirk Stolle

_realname=snowballstemmer
pkgname=python-${_realname}
pkgver=3.1.1
pkgrel=1
pkgdesc='Snowball stemming library collection for Python'
arch=('any')
url='https://github.com/snowballstem/snowball'
msys2_references=(
  'cygwin: python-snowballstemmer'
  'purl: pkg:pypi/snowballstemmer'
)
license=('spdx:BSD-3-Clause')
depends=('python')
makedepends=(
  'python-build'
  'python-installer'
  'python-setuptools'
)
source=("https://pypi.org/packages/source/${_realname::1}/${_realname}/${_realname}-${pkgver}.tar.gz")
sha256sums=('e07bbc54a0d798fe6010a12398422e62a8bfbba95c394fd0956ef58cb4d3e260')

build() {
  cp -r "${_realname}-${pkgver}" "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"

  python -m build --wheel --skip-dependency-check --no-isolation
}

check() {
  cd "python-build-${MSYSTEM}"

  PYTHONPATH=. python src/sample/testapp.py english "what's this"
}

package() {
  cd "python-build-${MSYSTEM}"

  python -m installer --prefix=${MSYSTEM_PREFIX} --destdir="${pkgdir}" dist/*.whl

  install -Dm644 COPYING "${pkgdir}${MSYSTEM_PREFIX}/share/licenses/python-${_realname}/LICENSE"
}
